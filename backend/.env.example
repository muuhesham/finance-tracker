PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/finance-flow
JWT_SECRET=replace-with-a-secure-secret
CLIENT_URL=http://localhost:5173

# ── Telegram Bot (optional) ──────────────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram → copy the token here
# 2. After deployment, call POST /api/webhooks/setup/telegram with your public URL
TELEGRAM_BOT_TOKEN=

# ── Discord Bot (optional) ───────────────────────────────────────────────────
# 1. Create an application at https://discord.com/developers/applications
# 2. Create a bot under the application, copy the token
# 3. Set Interactions Endpoint URL in the app portal to: https://yourdomain/api/webhooks/discord
# 4. Call POST /api/webhooks/setup/discord (authenticated) to register slash commands
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
